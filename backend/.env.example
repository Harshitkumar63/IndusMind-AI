# IndusMind AI Backend Environment Configuration
# Copy this file to .env and fill in the values

# ─── Application ───────────────────────────────────────────
APP_NAME=IndusMind AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
SECRET_KEY=your-super-secret-key-change-in-production

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://indusmind:indusmind_secret@localhost:5432/indusmind_db
DATABASE_SYNC_URL=postgresql://indusmind:indusmind_secret@localhost:5432/indusmind_db

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Authentication (Clerk) ───────────────────────────────
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# ─── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── ChromaDB ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=indusmind_documents

# ─── Neo4j ─────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=indusmind_neo4j

# ─── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── File Storage ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ─── AI Pipeline ──────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=10
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Demo Mode ─────────────────────────────────────────────
DEMO_MODE=true
